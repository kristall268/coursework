<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GitExplorer</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Global stylesheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Per-page styles -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="progress-bar"></div>

    <!-- ── Navbar ──────────────────────────────────────────── -->
    <nav id="navbar">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="7" fill="#161b22" stroke="#30363d" stroke-width="0.5"/>
                <path d="M14 3.5C8.75 3.5 4.5 7.75 4.5 13c0 4.12 2.67 7.62 6.37 8.85.47.09.64-.2.64-.45v-1.57c-2.6.56-3.14-1.25-3.14-1.25-.42-1.08-1.03-1.37-1.03-1.37-.84-.58.06-.57.06-.57.93.07 1.42.96 1.42.96.83 1.42 2.18 1.01 2.71.77.08-.6.32-1.01.58-1.24-2.07-.24-4.25-1.04-4.25-4.6 0-1.02.36-1.85.96-2.5-.1-.23-.42-1.18.09-2.46 0 0 .78-.25 2.57.96A8.84 8.84 0 0114 8.08c.79 0 1.59.11 2.34.31 1.79-1.21 2.57-.96 2.57-.96.51 1.28.19 2.23.09 2.46.6.65.96 1.48.96 2.5 0 3.57-2.18 4.36-4.25 4.6.33.29.63.86.63 1.73v2.56c0 .25.17.54.64.45C20.84 20.62 23.5 17.12 23.5 13 23.5 7.75 19.25 3.5 14 3.5z" fill="#58a6ff"/>
            </svg>
            <span>
                <span class="nav-logo-text">GitExplorer</span>
                <span class="nav-logo-sub">Open Source Discovery</span>
            </span>
        </a>

        <div class="nav-divider"></div>

        <div class="nav-search-wrap">
            <span class="nav-search-icon">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M11.742 10.344a6.5 6.5 0 10-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 001.415-1.414l-3.85-3.85a1.007 1.007 0 00-.115-.1zM12 6.5a5.5 5.5 0 11-11 0 5.5 5.5 0 0111 0z"/>
                </svg>
            </span>
            <input class="nav-search" type="text" placeholder="Search repos, topics, users..."
                   id="nav-search-input"
                   onkeydown="if(event.key==='Enter'){window.location='/explore?query='+encodeURIComponent(this.value)}" />
            <kbd class="nav-search-kbd">/</kbd>
        </div>

        <nav class="nav-links">
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Explore"  ? "active" : "")"
               asp-controller="Explore" asp-action="Index">Explore</a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Trending" ? "active" : "")"
               asp-controller="Trending" asp-action="Index">Trending</a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Compare"  ? "active" : "")"
               asp-controller="Compare" asp-action="Index">Compare</a>
        </nav>

        <div class="nav-spacer"></div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="nav-link" asp-controller="Account" asp-action="Collections">Collections</a>
            <img class="nav-avatar"
                 src="@User.FindFirst("urn:github:avatar")?.Value"
                 alt="@User.Identity.Name"
                 title="@User.Identity.Name"
                 onerror="this.style.display='none'" />
            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline" style="padding:5px 12px;font-size:12px">Sign out</button>
            </form>
        }
        else
        {
            <a class="nav-signin" asp-controller="Account" asp-action="SignIn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                Sign in with GitHub
            </a>
        }
    </nav>

    <!-- ── Page Content ────────────────────────────────────── -->
    <div id="page-body">
        @RenderBody()
    </div>

    <!-- ── Footer ──────────────────────────────────────────── -->
    <footer>
        <div>
            Built with ASP.NET Core 10 · Powered by
            <a href="https://docs.github.com/en/rest" target="_blank">GitHub API</a> ·
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script>
        // Progress bar on navigation
        const bar = document.getElementById('progress-bar');
        bar.style.width = '100%';
        setTimeout(() => { bar.style.opacity = '0'; }, 400);

        // Keyboard shortcut: / → focus search
        document.addEventListener('keydown', e => {
            if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
                e.preventDefault();
                document.getElementById('nav-search-input')?.focus();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
