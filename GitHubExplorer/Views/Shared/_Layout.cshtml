<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GitExplorer</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:           #0d1117;
            --bg2:          #161b22;
            --bg3:          #21262d;
            --border:       #30363d;
            --border-hover: #58a6ff;
            --accent:       #58a6ff;
            --accent-dim:   rgba(88,166,255,0.12);
            --text:         #e6edf3;
            --text2:        #8b949e;
            --text3:        #484f58;
            --success:      #3fb950;
            --warning:      #d29922;
            --danger:       #f85149;
            --nav-h:        60px;
            --font:         'Geist', system-ui, sans-serif;
            --mono:         'JetBrains Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: var(--font);
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }

        ::selection { background: rgba(88,166,255,0.25); }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

        /* ── Progress bar ── */
        #progress-bar {
            position: fixed; top: 0; left: 0; height: 2px; width: 0;
            background: var(--accent); z-index: 9999;
            transition: width 0.3s ease;
        }

        /* ── Navbar ── */
        #navbar {
            position: fixed; top: 0; left: 0; right: 0; height: var(--nav-h);
            background: rgba(13,17,23,0.92);
            backdrop-filter: blur(16px) saturate(160%);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 12px;
            padding: 0 20px; z-index: 100;
        }

        /* ── Logo ── */
        .nav-logo {
            display: flex; align-items: center; gap: 8px;
            text-decoration: none; flex-shrink: 0;
        }
        .nav-logo svg { flex-shrink: 0; }
        .nav-logo-text { font-size: 15px; font-weight: 700; color: var(--text); letter-spacing: -0.3px; }
        .nav-logo-sub { font-size: 10px; color: var(--text3); display: block; margin-top: -2px; }

        .nav-divider { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }

        /* ── Search ── */
        .nav-search-wrap { flex: 1; max-width: 440px; position: relative; }
        .nav-search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); pointer-events: none; }
        .nav-search {
            width: 100%; background: var(--bg3); border: 1px solid var(--border);
            border-radius: 6px; color: var(--text); padding: 7px 36px 7px 32px;
            font-size: 13px; font-family: var(--font); outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .nav-search::placeholder { color: var(--text3); }
        .nav-search:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(88,166,255,0.12); }
        .nav-search-kbd {
            position: absolute; right: 9px; top: 50%; transform: translateY(-50%);
            background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
            padding: 1px 5px; font-size: 10px; color: var(--text3); font-family: var(--mono);
        }

        /* ── Nav links ── */
        .nav-links { display: flex; align-items: center; gap: 2px; }
        .nav-link {
            background: none; border: none; cursor: pointer; font-family: var(--font);
            color: var(--text2); font-size: 13px; font-weight: 400;
            padding: 6px 11px; border-radius: 6px; position: relative;
            transition: color 0.15s, background 0.15s; text-decoration: none;
            display: block;
        }
        .nav-link:hover { background: var(--bg3); color: var(--text); text-decoration: none; }
        .nav-link.active { color: var(--accent); font-weight: 600; }
        .nav-link.active::after {
            content: ''; position: absolute; bottom: -11px; left: 0; right: 0;
            height: 2px; background: var(--accent); border-radius: 2px;
        }

        .nav-spacer { flex: 1; }

        /* ── Sign in button ── */
        .nav-signin {
            display: flex; align-items: center; gap: 6px;
            background: var(--accent); border: none; border-radius: 6px;
            color: #0d1117; padding: 6px 14px; cursor: pointer;
            font-family: var(--font); font-size: 13px; font-weight: 600;
            flex-shrink: 0; transition: opacity 0.15s;
            text-decoration: none;
            white-space: nowrap;
        }
        .nav-signin:hover { opacity: 0.85; text-decoration: none; color: #0d1117; }

        /* ── Avatar (logged in) ── */
        .nav-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            border: 2px solid var(--border); cursor: pointer;
            transition: border-color 0.15s; flex-shrink: 0;
        }
        .nav-avatar:hover { border-color: var(--accent); }

        /* ── Page body ── */
        #page-body { padding-top: var(--nav-h); }

        /* ── Footer ── */
        footer {
            border-top: 1px solid var(--border);
            padding: 20px;
            text-align: center;
            color: var(--text3);
            font-size: 12px;
            margin-top: 60px;
        }
        footer a { color: var(--text2); }
        footer a:hover { color: var(--accent); }

        /* ── Utilities ── */
        .container { max-width: 1280px; margin: 0 auto; padding: 0 20px; }

        .btn {
            display: inline-flex; align-items: center; gap: 6px;
            border-radius: 6px; padding: 8px 18px; font-size: 13px;
            font-family: var(--font); font-weight: 500; cursor: pointer;
            transition: all 0.15s; text-decoration: none; border: none;
        }
        .btn-primary { background: var(--accent); color: #0d1117; font-weight: 600; }
        .btn-primary:hover { opacity: 0.85; color: #0d1117; text-decoration: none; }
        .btn-outline { background: none; border: 1px solid var(--border); color: var(--text); }
        .btn-outline:hover { border-color: var(--accent); background: var(--accent-dim); color: var(--text); text-decoration: none; }

        .tag {
            display: inline-flex; align-items: center;
            background: var(--accent-dim); border: 1px solid rgba(88,166,255,0.3);
            border-radius: 20px; padding: 2px 9px; font-size: 11px;
            color: var(--accent); font-weight: 500;
        }

        .lang-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; flex-shrink: 0; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s ease forwards; }

        @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
        .live-dot { animation: pulse 2s ease infinite; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="progress-bar"></div>

    <!-- ── Navbar ─────────────────────────────────────────── -->
    <nav id="navbar">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="7" fill="#161b22" stroke="#30363d" stroke-width="0.5"/>
                <path d="M14 3.5C8.75 3.5 4.5 7.75 4.5 13c0 4.12 2.67 7.62 6.37 8.85.47.09.64-.2.64-.45v-1.57c-2.6.56-3.14-1.25-3.14-1.25-.42-1.08-1.03-1.37-1.03-1.37-.84-.58.06-.57.06-.57.93.07 1.42.96 1.42.96.83 1.42 2.18 1.01 2.71.77.08-.6.32-1.01.58-1.24-2.07-.24-4.25-1.04-4.25-4.6 0-1.02.36-1.85.96-2.5-.1-.23-.42-1.18.09-2.46 0 0 .78-.25 2.57.96A8.84 8.84 0 0114 8.08c.79 0 1.59.11 2.34.31 1.79-1.21 2.57-.96 2.57-.96.51 1.28.19 2.23.09 2.46.6.65.96 1.48.96 2.5 0 3.57-2.18 4.36-4.25 4.6.33.29.63.86.63 1.73v2.56c0 .25.17.54.64.45C20.84 20.62 23.5 17.12 23.5 13 23.5 7.75 19.25 3.5 14 3.5z" fill="#58a6ff"/>
            </svg>
            <span>
                <span class="nav-logo-text">GitExplorer</span>
                <span class="nav-logo-sub">Open Source Discovery</span>
            </span>
        </a>

        <div class="nav-divider"></div>

        <div class="nav-search-wrap">
            <span class="nav-search-icon">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M11.742 10.344a6.5 6.5 0 10-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 001.415-1.414l-3.85-3.85a1.007 1.007 0 00-.115-.1zM12 6.5a5.5 5.5 0 11-11 0 5.5 5.5 0 0111 0z"/>
                </svg>
            </span>
            <input class="nav-search" type="text" placeholder="Search repos, topics, users..."
                   id="nav-search-input"
                   onkeydown="if(event.key==='Enter'){window.location='/explore?query='+encodeURIComponent(this.value)}" />
            <kbd class="nav-search-kbd">/</kbd>
        </div>

        <nav class="nav-links">
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Explore"  ? "active" : "")"
               asp-controller="Explore" asp-action="Index">Explore</a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Trending" ? "active" : "")"
               asp-controller="Trending" asp-action="Index">Trending</a>
            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Compare"  ? "active" : "")"
               asp-controller="Compare" asp-action="Index">Compare</a>
        </nav>

        <div class="nav-spacer"></div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="nav-link" asp-controller="Account" asp-action="Collections">Collections</a>
            <img class="nav-avatar"
                 src="@User.FindFirst("urn:github:avatar")?.Value"
                 alt="@User.Identity.Name"
                 title="@User.Identity.Name" />
            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline" style="padding:5px 12px;font-size:12px">Sign out</button>
            </form>
        }
        else
        {
            <a class="nav-signin" asp-controller="Account" asp-action="SignIn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                Sign in with GitHub
            </a>
        }
    </nav>

    <!-- ── Page Content ───────────────────────────────────── -->
    <div id="page-body">
        @RenderBody()
    </div>

    <!-- ── Footer ─────────────────────────────────────────── -->
    <footer>
        <div>
            Built with ASP.NET Core 10 · Powered by
            <a href="https://docs.github.com/en/rest" target="_blank">GitHub API</a> ·
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script>
        // Progress bar on navigation
        const bar = document.getElementById('progress-bar');
        bar.style.width = '100%';
        setTimeout(() => { bar.style.opacity = '0'; }, 400);

        // Keyboard shortcut: / → focus search
        document.addEventListener('keydown', e => {
            if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
                e.preventDefault();
                document.getElementById('nav-search-input')?.focus();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
