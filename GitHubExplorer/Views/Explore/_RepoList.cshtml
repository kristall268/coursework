@model GitHubExplorer.Models.ViewModels.ExploreViewModel
@*
    Partial view — returned by ExploreController.Index when X-Requested-With: XMLHttpRequest
    Also rendered inline by Explore/Index.cshtml on first load.

    Required CSS (add to Explore/Index.cshtml @section Styles):

    .results-meta {
        display: flex; align-items: center; gap: 8px;
        font-size: 12px; color: var(--text2); margin-bottom: 14px; flex-wrap: wrap;
    }
    .results-count strong { color: var(--text); }
    .results-query em { color: var(--accent); font-style: normal; }

    .repo-list { display: flex; flex-direction: column; gap: 10px; }

    .pagination {
        display: flex; align-items: center; justify-content: center;
        gap: 4px; margin-top: 28px; flex-wrap: wrap;
    }
    .page-btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 34px; height: 34px; padding: 0 10px;
        background: var(--bg2); border: 1px solid var(--border);
        border-radius: 6px; font-size: 13px; color: var(--text2);
        text-decoration: none; transition: all 0.15s; cursor: pointer;
    }
    .page-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
    .page-btn--active {
        background: var(--accent); border-color: var(--accent);
        color: #0d1117; font-weight: 600; pointer-events: none;
    }
    .page-btn--disabled { opacity: 0.35; pointer-events: none; cursor: default; }
    .page-ellipsis { color: var(--text3); padding: 0 4px; line-height: 34px; font-size: 13px; }

    .explore-empty {
        display: flex; flex-direction: column; align-items: center;
        gap: 6px; padding: 60px 20px; text-align: center;
        color: var(--text3);
    }
    .explore-empty p    { font-size: 14px; font-weight: 500; color: var(--text2); margin-top: 12px; }
    .explore-empty span { font-size: 12px; }


    Renders:
      • Result count bar
      • Repo cards grid (via _RepoCard partial)
      • Empty state
      • Pagination
*@

@{
    bool hasResults = Model.Repositories.Count > 0;
}

<!-- ── Results meta bar ── -->
<div class="results-meta">
    @if (Model.TotalCount > 0)
    {
        var from = (Model.Filter.Page - 1) * Model.Filter.PageSize + 1;
        var to   = Math.Min(Model.Filter.Page * Model.Filter.PageSize, Model.TotalCount);
        <span class="results-count">
            Showing <strong>@from–@to</strong> of
            <strong>@Model.TotalCount.ToString("N0")</strong> repositories
        </span>
    }
    else if (hasResults)
    {
        <span class="results-count">@Model.Repositories.Count repositories</span>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Filter.Query))
    {
        <span class="results-query">
            for <em>"@Model.Filter.Query"</em>
        </span>
    }
</div>

<!-- ── Repo cards ── -->
@if (hasResults)
{
    <div class="repo-list" id="repo-list">
        @foreach (var repo in Model.Repositories)
        {
            @await Html.PartialAsync("_RepoCard", repo,
                new ViewDataDictionary(ViewData) { ["ShowFavorite"] = true })
        }
    </div>

    <!-- ── Pagination ── -->
    @if (Model.TotalPages > 1)
    {
        <nav class="pagination" aria-label="Repository pages">
            @* Previous *@
            @if (Model.HasPreviousPage)
            {
                <a class="page-btn"
                   asp-controller="Explore" asp-action="Index"
                   asp-route-query="@Model.Filter.Query"
                   asp-route-language="@Model.Filter.Language"
                   asp-route-topic="@Model.Filter.Topic"
                   asp-route-license="@Model.Filter.License"
                   asp-route-minStars="@Model.Filter.MinStars"
                   asp-route-sort="@Model.Filter.Sort"
                   asp-route-order="@Model.Filter.Order"
                   asp-route-page="@(Model.Filter.Page - 1)">
                    ← Prev
                </a>
            }
            else
            {
                <span class="page-btn page-btn--disabled">← Prev</span>
            }

            @* Page numbers — show up to 7 around current *@
            @{
                int total   = Model.TotalPages;
                int current = Model.Filter.Page;
                var pages   = new List<int?>();

                if (total <= 7)
                {
                    for (int i = 1; i <= total; i++) pages.Add(i);
                }
                else
                {
                    pages.Add(1);
                    if (current > 3) pages.Add(null); // ellipsis
                    for (int i = Math.Max(2, current - 1); i <= Math.Min(total - 1, current + 1); i++)
                        pages.Add(i);
                    if (current < total - 2) pages.Add(null); // ellipsis
                    pages.Add(total);
                }
            }

            @foreach (var p in pages)
            {
                if (p is null)
                {
                    <span class="page-ellipsis">…</span>
                }
                else if (p == current)
                {
                    <span class="page-btn page-btn--active">@p</span>
                }
                else
                {
                    <a class="page-btn"
                       asp-controller="Explore" asp-action="Index"
                       asp-route-query="@Model.Filter.Query"
                       asp-route-language="@Model.Filter.Language"
                       asp-route-topic="@Model.Filter.Topic"
                       asp-route-license="@Model.Filter.License"
                       asp-route-minStars="@Model.Filter.MinStars"
                       asp-route-sort="@Model.Filter.Sort"
                       asp-route-order="@Model.Filter.Order"
                       asp-route-page="@p">
                        @p
                    </a>
                }
            }

            @* Next *@
            @if (Model.HasNextPage)
            {
                <a class="page-btn"
                   asp-controller="Explore" asp-action="Index"
                   asp-route-query="@Model.Filter.Query"
                   asp-route-language="@Model.Filter.Language"
                   asp-route-topic="@Model.Filter.Topic"
                   asp-route-license="@Model.Filter.License"
                   asp-route-minStars="@Model.Filter.MinStars"
                   asp-route-sort="@Model.Filter.Sort"
                   asp-route-order="@Model.Filter.Order"
                   asp-route-page="@(Model.Filter.Page + 1)">
                    Next →
                </a>
            }
            else
            {
                <span class="page-btn page-btn--disabled">Next →</span>
            }
        </nav>
    }
}
else
{
    <!-- ── Empty state ── -->
    <div class="explore-empty">
        <svg width="40" height="40" viewBox="0 0 16 16" fill="currentColor" opacity="0.25">
            <path d="M11.742 10.344a6.5 6.5 0 10-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 001.415-1.414l-3.85-3.85a1.007 1.007 0 00-.115-.1zM12 6.5a5.5 5.5 0 11-11 0 5.5 5.5 0 0111 0z"/>
        </svg>
        <p>No repositories found.</p>
        <span>Try adjusting your search or removing some filters.</span>
        <a class="btn btn-outline"
           asp-controller="Explore" asp-action="Index"
           style="margin-top:14px;display:inline-flex">
            Clear all filters
        </a>
    </div>
}
