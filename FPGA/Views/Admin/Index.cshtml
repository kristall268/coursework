@model FPGA.Models.UserAdminViewModel
@{
    ViewData["Title"] = "Управление пользователями";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section" style="padding-top:7rem;">
    <div class="container">
        <div class="section-header" style="text-align:left; margin-bottom:2rem;">
            <h2 class="section-title" style="font-size:1.8rem;">Управление пользователями</h2>
            <p class="section-subtitle" style="text-align:left;">Всего пользователей: <strong>@Model.Users.Count</strong></p>
        </div>

        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success" style="margin-bottom:1.5rem;">@ok</div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-error" style="margin-bottom:1.5rem;">@err</div>
        }

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Пользователь</th>
                        <th>Email</th>
                        <th>Роль</th>
                        <th>Статус</th>
                        <th>Зарегистрирован</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        var roleClass = user.Role switch {
                            "Admin"   => "badge-advanced",
                            "Teacher" => "badge-intermediate",
                            _         => "badge-beginner"
                        };
                        var roleName = user.Role switch {
                            "Admin"   => "Админ",
                            "Teacher" => "Преподаватель",
                            _         => "Обучающийся"
                        };

                        <tr class="@(user.IsActive ? "" : "row-inactive")">
                            <td style="color:var(--text-muted);">#@user.Id</td>
                            <td>
                                <strong>@user.Username</strong>
                                @if (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == user.Id.ToString())
                                {
                                    <span class="badge badge-lang" style="margin-left:0.4rem; font-size:0.65rem;">Вы</span>
                                }
                            </td>
                            <td style="color:var(--text-secondary); font-size:0.85rem;">@user.Email</td>
                            <td><span class="badge @roleClass">@roleName</span></td>
                            <td>
                                <span class="badge @(user.IsActive ? "badge-beginner" : "badge-advanced")" style="font-size:0.72rem;">
                                    @(user.IsActive ? "Активен" : "Заблокирован")
                                </span>
                            </td>
                            <td style="color:var(--text-muted); font-size:0.82rem;">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="admin-actions">
                                    <!-- Change Role -->
                                    <form asp-action="SetRole" method="post" style="display:inline-flex; gap:0.3rem; align-items:center;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="role" class="filter-select" style="padding:0.3rem 0.5rem; font-size:0.78rem;">
                                            <option value="Student"  selected="@(user.Role == "Student"  ? "selected" : null)">Обучающийся</option>
                                            <option value="Teacher"  selected="@(user.Role == "Teacher"  ? "selected" : null)">Преподаватель</option>
                                            <option value="Admin"    selected="@(user.Role == "Admin"    ? "selected" : null)">Админ</option>
                                        </select>
                                        <button type="submit" class="btn-sm btn-outline-sm">Сохранить</button>
                                    </form>

                                    <!-- Toggle Active -->
                                    <form asp-action="ToggleActive" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn-sm @(user.IsActive ? "btn-warn-sm" : "btn-ok-sm")">
                                            @(user.IsActive ? "Блок" : "Разблок")
                                        </button>
                                    </form>

                                    <!-- Delete -->
                                    @if (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value != user.Id.ToString())
                                    {
                                        <form asp-action="Delete" method="post" style="display:inline;"
                                              onsubmit="return confirm('Удалить пользователя @user.Username?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn-sm btn-danger-sm">Удалить</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
