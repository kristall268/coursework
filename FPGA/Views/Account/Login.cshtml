@model FPGA.Models.LoginViewModel
@{
    ViewData["Title"] = "Вход";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-section">
    <div class="auth-box">
        <div class="auth-header">
            <div class="brand-icon" style="margin: 0 auto 1rem; width:48px; height:48px; font-size:1.2rem;">F</div>
            <h1>Добро пожаловать</h1>
            <p>Войдите в свой аккаунт FPGA Learn</p>
        </div>

        @if (TempData["Success"] is string msg)
        {
            <div class="alert alert-success">@msg</div>
        }

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Username">Имя пользователя</label>
                <input asp-for="Username" class="form-input" placeholder="your_username" autocomplete="username" />
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-check">
                <input asp-for="Remember" type="checkbox" id="remember" />
                <label for="remember">Запомнить меня на 30 дней</label>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:0.5rem;">
                Войти
            </button>
        </form>

        <div class="auth-footer">
            <span>Нет аккаунта?</span>
            <a asp-controller="Account" asp-action="Register">Зарегистрироваться</a>
        </div>

        <div class="auth-hint">
            <p>Тестовые аккаунты:</p>
            <code>admin / Admin123!</code>
            <code>teacher / Teacher123!</code>
            <code>student / Student123!</code>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
