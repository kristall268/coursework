<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FPGA Learn</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-icon">F</div>
                <span>FPGA Learn</span>
            </a>
            <div class="navbar-links">
                <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a>
                <a asp-controller="Components" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Components" ? "active" : "")">Components</a>
                <a asp-controller="Projects" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")">Projects</a>
                <a asp-controller="Practice" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Practice" ? "active" : "")">Practice</a>
            </div>
            <button class="theme-toggle" id="themeToggle" title="Toggle theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            </button>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-col">
                <h4>Documentation</h4>
                <ul>
                    <li><a href="#">Getting Started</a></li>
                    <li><a href="#">Verilog Guide</a></li>
                    <li><a href="#">VHDL Reference</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Community</h4>
                <ul>
                    <li><a href="#">GitHub</a></li>
                    <li><a href="#">Discussions</a></li>
                    <li><a href="#">Issues</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>About</h4>
                <ul>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                    <li><a href="#">License</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2024 FPGA Learning Platform. All rights reserved.</p>
            <div class="footer-icons">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
