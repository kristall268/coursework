@model FPGA.Models.ProjectsViewModel
@{
    ViewData["Title"] = "Projects & HDL Explorer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ── CODE EXPLORER ────────────────────────────────────────────── -->
<section class="section explorer-section" style="padding-top:7rem;">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Code Explorer</h2>
            <p class="section-subtitle">Browse and search HDL modules across different languages and difficulty levels</p>
        </div>

        <div class="explorer-search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="hdlSearch" type="text" placeholder="Search HDL modules..." autocomplete="off" />
        </div>

        <div class="explorer-filters">
            <select id="langFilter" class="filter-select">
                <option value="all">Language: All</option>
                <option value="verilog">Verilog</option>
                <option value="vhdl">VHDL</option>
                <option value="systemverilog">SystemVerilog</option>
            </select>
            <select id="diffFilter" class="filter-select">
                <option value="all">Difficulty: All</option>
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced</option>
            </select>
        </div>

        <div class="hdl-list">
            @foreach (var module in Model.HdlModules)
            {
                var langLower = module.Language.ToLower().Replace(" ", "");
                var diffLower = module.Difficulty.ToLower();
                var langBadgeClass = langLower == "vhdl" ? "badge-vhdl" : langLower == "systemverilog" ? "badge-sv" : "badge-lang";
                var diffBadgeClass = $"badge-{diffLower}";

                <div class="hdl-item" data-lang="@langLower" data-diff="@diffLower">
                    <div class="hdl-badges">
                        <span class="badge @langBadgeClass">@module.Language</span>
                        <span class="badge @diffBadgeClass">@module.Difficulty</span>
                    </div>
                    <h4>@module.Title</h4>
                    <p>@module.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── FPGA PROJECTS ─────────────────────────────────────────────── -->
<section class="section projects-section" id="fpga-projects">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">FPGA Projects</h2>
            <p class="section-subtitle">Build real-world FPGA applications from beginner-friendly to advanced projects</p>
        </div>

        <div class="projects-grid">
            @foreach (var project in Model.Projects)
            {
                var diffClass = project.Difficulty.ToLower() switch {
                    "beginner"     => "badge-beginner",
                    "intermediate" => "badge-intermediate",
                    _              => "badge-advanced"
                };

                <div class="project-card">
                    <div class="project-header">
                        <h3>@project.Title</h3>
                        <span class="badge @diffClass">@project.Difficulty</span>
                    </div>
                    <div class="project-tags">
                        @foreach (var tag in project.Tags)
                        {
                            <span class="project-tag">@tag</span>
                        }
                    </div>
                    <a asp-controller="Projects" asp-action="Details" asp-route-slug="@project.Slug" class="btn-project">
                        Start Project
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                </div>
            }
        </div>
    </div>
</section>
