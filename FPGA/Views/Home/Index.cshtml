@model FPGA.Models.HomeViewModel
@{
    ViewData["Title"] = "FPGA & Digital Logic Learning Platform";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ── HERO ──────────────────────────────────────────────────────── -->
<section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-content">
        <h1 class="hero-title">
            FPGA &amp; <span class="gradient-text">Digital Logic<br>Learning</span> Platform
        </h1>
        <p class="hero-subtitle">
            From logic gates to hardware implementation. Master VHDL, Verilog, and
            SystemVerilog with hands-on FPGA design projects.
        </p>
        <div class="hero-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                Start Learning
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a asp-controller="Projects" asp-action="Index" class="btn btn-outline">
                Explore HDL Code
            </a>
        </div>
        <div class="hero-tags">
            <span class="label">Learn from industry leaders</span>
            <span class="tag">Verilog</span>
            <span class="tag">VHDL</span>
            <span class="tag">SystemVerilog</span>
            <span class="tag">FPGA Design</span>
        </div>
    </div>
</section>

<!-- ── LEARNING PATH ─────────────────────────────────────────────── -->
<section class="section learning-path" id="learning-path">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Learning Path</h2>
            <p class="section-subtitle">Follow a structured curriculum from fundamentals to advanced FPGA implementation</p>
        </div>
        <div class="path-steps">
            @foreach (var step in Model.LearningSteps)
            {
                <div class="path-step">
                    <div class="step-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            @if (step.Order == 1)
                            {
                                <polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                            }
                            else if (step.Order <= 3)
                            {
                                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                            }
                            else if (step.Order == 4)
                            {
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                            }
                            else
                            {
                                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                            }
                        </svg>
                    </div>
                    <div class="step-title">@step.Title</div>
                    <div class="step-desc">@step.Description</div>
                    @if (step.Order < Model.LearningSteps.Count)
                    {
                        <div class="step-arrow">→</div>
                    }
                </div>
            }
        </div>
    </div>
</section>

<!-- ── DIGITAL COMPONENTS LIBRARY ───────────────────────────────── -->
<section class="section components-section" id="components">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Digital Components Library</h2>
            <p class="section-subtitle">Explore essential digital components with theory, truth tables, and code implementations</p>
        </div>
        <div class="components-grid">
            @foreach (var comp in Model.FeaturedComponents)
            {
                <div class="component-card">
                    <div class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/>
                        </svg>
                    </div>
                    <h3>@comp.Title</h3>
                    <p>@comp.Description</p>
                    <a asp-controller="Components" asp-action="Details" asp-route-slug="@comp.Slug" class="btn-card">
                        View Details
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                </div>
            }
        </div>
        <div style="text-align:center;margin-top:2rem;">
            <a asp-controller="Components" asp-action="Index" class="btn btn-outline">
                View All Components
            </a>
        </div>
    </div>
</section>
