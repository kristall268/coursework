@model List<FPGA.Models.PracticeProblem>
@{
    ViewData["Title"] = "Practice Problems";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ── PRACTICE PROBLEMS ─────────────────────────────────────────── -->
<section class="section practice-section" style="padding-top:7rem;">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Practice Problems</h2>
            <p class="section-subtitle">Test your skills with hands-on design challenges and coding exercises</p>
        </div>

        <div class="practice-grid">
            @foreach (var problem in Model)
            {
                var diffClass = problem.Difficulty.ToLower() switch {
                    "beginner"     => "badge-beginner",
                    "intermediate" => "badge-intermediate",
                    _              => "badge-advanced"
                };

                <div class="practice-card">
                    <div class="practice-header">
                        <h3>@problem.Title</h3>
                        <span class="badge @diffClass">@problem.Difficulty</span>
                    </div>
                    <a asp-controller="Practice" asp-action="Solve" asp-route-slug="@problem.Slug" class="btn-solve">
                        Solve
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── CTA ───────────────────────────────────────────────────────── -->
<div class="cta-section">
    <div class="cta-box">
        <h2>Ready to master FPGA design?</h2>
        <p>Start with our comprehensive learning path and build your way to advanced FPGA projects</p>
        <a asp-controller="Home" asp-action="Index" asp-fragment="learning-path" class="btn btn-cta">
            Begin Your Journey
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
    </div>
</div>
